<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Mic capture under Hardened Runtime. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <key>com.apple.security.device.microphone</key>
    <true/>
    <!-- Keychain access for the API key under Hardened Runtime (needs the app's own group;
         $(AppIdentifierPrefix) is the Team ID prefix, substituted at sign time). -->
    <key>keychain-access-groups</key>
    <array>
        <string>K542ZFQH6B.com.sebastianmarambio.transcribe</string>
    </array>
</dict>
</plist>
